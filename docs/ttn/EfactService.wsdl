<definitions
  targetNamespace="http://services.elfatoura.tradenet.com.tn/"
  name="EfactServiceService">

  <types>
    <xsd:schema>
      <xsd:import
        namespace="http://services.elfatoura.tradenet.com.tn/"
        schemaLocation="http://elfatoura.tradenet.com.tn:80/ElfatouraServices/EfactService?xsd=1" />
    </xsd:schema>
  </types>

  <message name="consultEfact">
    <part name="parameters" element="tns:consultEfact" />
  </message>

  <message name="consultEfactResponse">
    <part name="parameters" element="tns:consultEfactResponse" />
  </message>

  <message name="saveEfact">
    <part name="parameters" element="tns:saveEfact" />
  </message>

  <message name="saveEfactResponse">
    <part name="parameters" element="tns:saveEfactResponse" />
  </message>

  <message name="verifyQrCode">
    <part name="parameters" element="tns:verifyQrCode" />
  </message>

  <message name="verifyQrCodeResponse">
    <part name="parameters" element="tns:verifyQrCodeResponse" />
  </message>

  <portType name="EfactService">
    <operation name="consultEfact">
      <input
        wsam:Action="http://services.elfatoura.tradenet.com.tn/EfactService/consultEfactRequest"
        message="tns:consultEfact" />
      <output
        wsam:Action="http://services.elfatoura.tradenet.com.tn/EfactService/consultEfactResponse"
        message="tns:consultEfactResponse" />
    </operation>

    <operation name="saveEfact">
      <input
        wsam:Action="http://services.elfatoura.tradenet.com.tn/EfactService/saveEfactRequest"
        message="tns:saveEfact" />
      <output
        wsam:Action="http://services.elfatoura.tradenet.com.tn/EfactService/saveEfactResponse"
        message="tns:saveEfactResponse" />
    </operation>

    <operation name="verifyQrCode">
      <input
        wsam:Action="http://services.elfatoura.tradenet.com.tn/EfactService/verifyQrCodeRequest"
        message="tns:verifyQrCode" />
      <output
        wsam:Action="http://services.elfatoura.tradenet.com.tn/EfactService/verifyQrCodeResponse"
        message="tns:verifyQrCodeResponse" />
    </operation>
  </portType>

  <binding
    name="EfactServicePortBinding"
    type="tns:EfactService">

    <soap:binding
      transport="http://schemas.xmlsoap.org/soap/http"
      style="document" />

    <operation name="consultEfact">
      <soap:operation soapAction="" />
      <input>
        <soap:body use="literal" />
      </input>
      <output>
        <soap:body use="literal" />
      </output>
    </operation>

    <operation name="saveEfact">
      <soap:operation soapAction="" />
      <input>
        <soap:body use="literal" />
      </input>
      <output>
        <soap:body use="literal" />
      </output>
    </operation>

    <operation name="verifyQrCode">
      <soap:operation soapAction="" />
      <input>
        <soap:body use="literal" />
      </input>
      <output>
        <soap:body use="literal" />
      </output>
    </operation>
  </binding>

  <service name="EfactServiceService">
    <port
      name="EfactServicePort"
      binding="tns:EfactServicePortBinding">
      <soap:address
        location="http://elfatoura.tradenet.com.tn:80/ElfatouraServices/EfactService" />
    </port>
  </service>

</definitions>