{
  "name": "tkr-elfatoora-api",
  "version": "0.1.0",
  "description": "Middleware API for TEIF electronic invoicing: JSON validation, TEIF XML generation, digital signing via ngsign, TTN submission, polling, signature verification, and webhooks for third-party invoicing systems.",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Tekru Technologies",
      "url": "https://tekru.net/"
    },
    {
      "name": "NGSign",
      "url": "https://www.ng-sign.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git@gitlab.tekru.net:tekru/elfatoora-api.git"
  },
  "homepage": "https://gitlab.tekru.net/tekru/elfatoora-api",
  "bugs": {
    "url": "https://gitlab.tekru.net/tekru/elfatoora-api/-/issues"
  },
  "keywords": [
    "invoicing",
    "teif",
    "tunisia",
    "electronic-invoicing",
    "xml",
    "digital-signing",
    "tax-authority",
    "ttn",
    "ngsign",
    "middleware",
    "api"
  ],
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "tsx --test",
    "test:watch": "tsx --test --watch",
    "test:e2e": "tsx --test 'src/__tests__/e2e/documents.e2e.test.ts' 'src/__tests__/e2e/examples.e2e.test.ts'",
    "test:e2e:watch": "tsx --test --watch 'src/__tests__/e2e/documents.e2e.test.ts' 'src/__tests__/e2e/examples.e2e.test.ts'",
    "test:e2e:real": "tsx --test --test-reporter=spec 'src/__tests__/e2e/**/*.real.e2e.test.ts'",
    "test:e2e:real:watch": "tsx --test --watch 'src/__tests__/e2e/**/*.real.e2e.test.ts'",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.3.3",
    "kysely": "^0.28.9",
    "kysely-postgres-js": "^3.0.0",
    "node-cron": "^4.2.1",
    "postgres": "^3.4.8",
    "ssh2-sftp-client": "^12.0.1",
    "url-join": "^5.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22",
    "@types/ssh2-sftp-client": "9.0.6",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
