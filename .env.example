# PostgreSQL (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/e_fatoura

# Public base URL for callback URLs
PUBLIC_BASE_URL=http://localhost:3000

# TTN Handling mode (WS = SOAP web service, SFTP = file transfer)
TTN_HANDLING_MODE=WS

# TTN SOAP endpoint (optional, defaults to Tradenet production)
TTN_SOAP_URL=http://elfatoura.tradenet.com.tn:80/ElfatouraServices/EfactService
TTN_SOAP_TIMEOUT=10000

# TTN SFTP (optional, only if TTN_HANDLING_MODE=SFTP)
TTN_SFTP_HOST=
TTN_SFTP_PORT=22

# Global API key for /v1/clients management endpoints
GLOBAL_API_KEY=il09luq402okmn6mk70zk9ms7ulw06yu

# NGSign (set to false when NGSign is connected)
NGSIGN_SKIP=true

# JWT Secret (for smart-comptable integration)
JWT_SECRET=change-me-to-a-random-secret
